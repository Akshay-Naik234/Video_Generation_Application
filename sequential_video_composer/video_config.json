{
  "images_root": "../assets/images",
  "output": "sequential_video_output.mp4",
  "res": "1920x1080",
  "fps": 30,
  "image_duration": 4.0,
  "crossfade": 1.2,
  "zoom": 1.15,
  "effects_intensity": 0.7,
  "transition_style": "random",
